<Window x:Class="LabWork5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel LastChildFill="True">
        <ListView x:Name="DiskListView" DockPanel.Dock="Top" Height="Auto">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя диска" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Тип диска" DisplayMemberBinding="{Binding DriveType}"/>
                    <GridViewColumn Header="Файловая система" DisplayMemberBinding="{Binding DriveFormat}"/>
                    <GridViewColumn Header="Общий объем" DisplayMemberBinding="{Binding TotalSize}"/>
                    <GridViewColumn Header="Свободное место" DisplayMemberBinding="{Binding AvailableFreeSpace}"/>
                    <GridViewColumn Header="Всего свободного места" DisplayMemberBinding="{Binding TotalFreeSpace}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBox x:Name="CatalogTextBox" DockPanel.Dock="Bottom"/>
        <TabControl DockPanel.Dock="Bottom">
            <TabItem Header="Общая информация">Первая вкладка</TabItem>
            <TabItem Header="Топ 10 файлов">Вторая вкладка</TabItem>
        </TabControl>
    </DockPanel>
</Window>
