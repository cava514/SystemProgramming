<Window x:Class="LabWork6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork6"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBox x:Name="FileNameTextBox"/>
            <Button x:Name="OpenFileDialogButton" Content="..." Click="OpenFileDialogButton_Click"/>
            <Button x:Name="CalculateButton" Content="Вычислить" Click="CalculateButton_Click"/>
            <Label x:Name="HashMD5Label"/>
            <Label x:Name="HashSHALabel"/>
        </StackPanel>
    </Grid>
</Window>
